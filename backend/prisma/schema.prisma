// Prisma schema for WFM Club – Azure PostgreSQL Flexible Server
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  timezone  String   @default("Europe/London")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  agents    Agent[]
  schedules Schedule[]
  lobs      LineOfBusiness[]
}

// Line of Business – e.g. "Customer Service", "Tech Support"
model LineOfBusiness {
  id             String   @id @default(cuid())
  name           String
  description    String?
  color          String   @default("#6366f1") // hex colour for UI
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  agents    Agent[]
  schedules Schedule[]

  @@unique([name, organizationId])
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  name           String
  picture        String?
  googleId       String?       @unique
  role           String        @default("manager")  // admin | manager | agent
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  agent    Agent?    // if this user IS an agent
  sessions Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Agent {
  id             String   @id @default(cuid())
  agentCode      String
  name           String
  email          String
  phone          String?
  status         String   @default("active")  // active | inactive | on_leave
  skill          String   @default("mid")     // junior | mid | senior | lead
  team           String?
  hireDate       DateTime
  lobId          String?                       // Line of Business assignment
  lob            LineOfBusiness? @relation(fields: [lobId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  userId         String?  @unique             // portal login
  user           User?    @relation(fields: [userId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  agentSchedules AgentScheduleEntry[]
  shiftOverrides ShiftDayOverride[]

  @@unique([agentCode, organizationId])
}

// Per-agent per-day shift override (e.g. "Sandra works 10:00–19:00 on 20 Mar")
model ShiftDayOverride {
  id             String   @id @default(cuid())
  agentId        String
  agent          Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  overrideDate   DateTime // stored as UTC midnight for the day
  shiftStart     String?  // "09:00" – null when isOff=true
  shiftEnd       String?  // "18:00" – null when isOff=true
  isOff          Boolean  @default(false)
  note           String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([agentId, overrideDate])
}

model Schedule {
  id              String   @id @default(cuid())
  name            String
  weekStartDate   DateTime
  fromDate        DateTime?               // LOB schedule range start
  toDate          DateTime?               // LOB schedule range end
  lobId           String?                 // Line of Business
  lob             LineOfBusiness? @relation(fields: [lobId], references: [id])
  status          String   @default("draft")  // draft | published | archived
  settingsJson    String   @db.Text            // JSON blob of ScheduleSettings
  forecastJson    String   @db.Text
  requiredJson    String   @db.Text
  agentsJson      String   @db.Text
  projectionsJson String   @db.Text
  rosterJson      String   @db.Text
  breaksJson      String   @db.Text
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  agentEntries AgentScheduleEntry[]
}

// Denormalized per-agent per-week schedule for the agent portal
model AgentScheduleEntry {
  id         String   @id @default(cuid())
  scheduleId String
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  agentId    String
  agent      Agent    @relation(fields: [agentId], references: [id])
  entryJson  String   @db.Text  // JSON of one agent's week schedule + breaks
  createdAt  DateTime @default(now())

  @@unique([scheduleId, agentId])
}
