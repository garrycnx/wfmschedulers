# ─── Database (Azure SQL) ─────────────────────────────────────────────────────
# Format: sqlserver://SERVER.database.windows.net:1433;database=DB_NAME;user=USER;password=PASS;encrypt=true
DATABASE_URL="sqlserver://YOUR_SERVER.database.windows.net:1433;database=wfm_schedule_db;user=wfm_admin;password=YOUR_PASSWORD;encrypt=true;trustServerCertificate=false"

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-secure-random-string-at-least-32-chars"

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
APP_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,https://your-azure-domain.azurestaticapps.net

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Set the same client ID in the frontend VITE_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
