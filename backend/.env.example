# ─── Database (Azure PostgreSQL Flexible Server) ──────────────────────────────
# Format: postgresql://USER:PASSWORD@SERVER.postgres.database.azure.com:5432/DB_NAME?sslmode=require
# Get exact string from: Azure Portal → your PostgreSQL server → Connection strings → Prisma
DATABASE_URL="postgresql://wfm_admin:YOUR_PASSWORD@wfmschedulerssql.postgres.database.azure.com:5432/wfm-schedule-db?sslmode=require"

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-secure-random-string-at-least-32-chars"

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
APP_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,https://wfmschedulers.azurewebsites.net

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Must match VITE_GOOGLE_CLIENT_ID used on the frontend
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
